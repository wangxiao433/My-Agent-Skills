rt.tzinfo) < window.end


def redact_secret(text: str) -> str:
    redacted = text
    for pattern in SECRET_PATTERNS:
        redacted = pattern.sub(lambda match: f"{match.group(1)}=[REDACTED]" if pattern.groups >= 2 else "[REDACTED]", redacted)
    return redacted


def cache_key(url: str, token: str | None, params: dict[str, str] | None) -> str:
    payload = json.dumps({"url": url, "params": params or {}, "token_hash": hashlib.sha256(token.encode()).hexdigest() if token else ""}, sort_keys=True)
    return hashlib.sha256(payload.encode()).hexdigest()


def load_cached_json(cache_dir: Path | None, key: str, ttl_seconds: int) -> Any | None:
    if not cache_dir or ttl_seconds <= 0:
        return None
    cache_path = cache_dir / f"{key}.json"
    if not cache_path.exists():
        return None
    if datetime.now(timezone.utc).timestamp() - cache_path.stat().st_mtime > ttl_seconds:
        return None
    return json.loads(cache_path.read_text(encoding="utf-8"))


def store_cached_json(cache_dir: Path | None, key: str, payload: Any) -> None:
    if not cache_dir:
        return
    cache_dir.mkdir(parents=True, exist_ok=True)
    (cache_dir / f"{key}.json").write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")


def request_json(url: str, token: str | None = None, params: dict[str, str] | None = None, cache_dir: Path | None = None, cache_ttl_seconds: int = 0) -> Any:
    key = cache_key(url, token, params)
    cached = load_cached_json(cache_dir, key, cache_ttl_seconds)
    if cached is not None:
        return cached
    request_url = f"{url}?{urllib.parse.urlencode(params)}" if params else url
    headers = {"Accept": "application/vnd.github+json", "User-Agent": "daily-project-context-skill"}
    if token:
        headers["Authorization"] = f"Bearer {token}"
    with urllib.request.urlopen(urllib.request.Request(request_url, headers=headers), timeout=20) as response:
        payload = json.loads(response.read().decode("utf-8"))
    store_cached_json(cache_dir, key, payload)
    return payload


def add_record(records: list[dict[str, Any]], **kwargs: Any) -> None:
    records.append({key: value for key, value in kwargs.items() if value not in (None, "", [])})


def summarize_public_event(event: dict[str, Any], window: TimeWindow) -> list[dict[str, Any]]:
    repo = event.get("repo", {}).get("name", "unknown repository")
    payload = event.get("payload", {})
    kind = event.get("type", "UnknownEvent")
    timestamp = event.get("created_at")
    records: list[dict[str, Any]] = []
    if kind == "PushEvent":
        for commit in payload.get("commits", []) or [{"message": "pushed commits"}]:
            sha = commit.get("sha")
            add_record(records, source="github_public_events", kind="commit", repo=repo, summary=(commit.get("message") or "(no message)").strip(), timestamp=timestamp, url=f"https://github.com/{repo}/commit/{sha}" if sha else None)
    elif kind == "IssuesEvent":
        issue = payload.get("issue", {})
        add_record(records, source="github_public_events", kind="issue", repo=repo, summary=f"{payload.get('action', 'updated')} - {issue.get('title', '')}".strip(), timestamp=timestamp, url=issue.get("html_url"))
    elif kind == "PullRequestEvent":
        pr = payload.get("pull_request", {})
        add_record(records, source="github_public_events", kind="pull_request", repo=repo, summary=f"{payload.get('action', 'updated')} - {pr.get('title', '')}".strip(), timestamp=timestamp, url=pr.get("html_url"))
    elif kind in {"IssueCommentEvent", "PullRequestReviewEvent", "PullRequestReviewCommentEvent"}:
        add_record(records, source="github_public_events", kind="review_or_comment", repo=repo, summary=payload.get("action", "updated"), timestamp=timestamp)
    else:
        add_record(records, source="github_public_events", kind=kind, repo=repo, summary="captured activity", timestamp=timestamp)
    return records


def fetch_public_github_records(config: ScanConfig, window: TimeWindow) -> tuple[list[dict[str, Any]], list[str]]:
    if not config.include_public_events:
        return [], []
    try:
        events = request_json(f"https://api.github.com/users/{config.github_username}/events", token=config.github_token, params={"per_page": str(min(config.max_github_items, 100))}, cache_dir=config.cache_dir, cache_ttl_seconds=config.cache_ttl_seconds)
    except Exception as exc:
        return [], [f"GitHub public events failed: {exc}"]
    records = [record for event in events if event_time_in_window(event.get("created_at"), window) for record in summarize_public_event(event, window)]
    return records, []


def fetch_ci_records(config: ScanConfig, repo: str, sha: str, window: TimeWindow) -> tuple[list[dict[str, Any]], list[str]]:
    records: list[dict[str, Any]] = []
    errors: list[str] = []
    if not config.include_ci or not sha:
        return records, errors
    try:
        status = request_json(f"https://api.github.com/repos/{repo}/commits/{sha}/status", token=config.github_token, cache_dir=config.cache_dir, cache_ttl_seconds=config.cache_ttl_seconds)
        add_record(records, source="github_ci_status", kind="ci_status", repo=repo, summary=f"combined status {status.get('state', 'unknown')} for {sha[:7]}", timestamp=status.get("updated_at") or status.get("created_at"), url=status.get("target_url"))
    except Exception as exc:
        errors.append(f"CI status failed for {repo}@{sha[:7]}: {exc}")
    try:
        checks = request_json(f"https://api.github.com/repos/{repo}/commits/{sha}/check-runs", token=config.github_token, params={"per_page": str(min(config.max_github_items, 100))}, cache_dir=config.cache_dir, cache_ttl_seconds=config.cache_ttl_seconds)
        for check in checks.get("check_runs", []):
            timestamp = check.get("completed_at") or check.get("started_at")
            if timestamp and not event_time_in_window(timestamp, window):
                continue
            add_record(records, source="github_check_runs", kind="ci_check", repo=repo, summary=f"{check.get('name', 'check')} - {check.get('conclusion') or check.get('status', 'unknown')}", timestamp=timestamp, url=check.get("html_url"))
    except Exception as exc:
        errors.append(f"CI checks failed for {repo}@{sha[:7]}: {exc}")
    return records, errors


def fetch_pull_detail_records(config: ScanConfig, repo: str, pull_number: int, window: TimeWindow) -> tuple[list[dict[str, Any]], list[str]]:
    records: list[dict[str, Any]] = []
    errors: list[str] = []
    if not config.include_pr_details:
        return records, errors
    for endpoint, source, kind in (("issues", "github_pr_comments", "pr_comment"), ("pulls", "github_pr_reviews", "pr_review")):
        url = f"https://api.github.com/repos/{repo}/{endpoint}/{pull_number}/comments" if endpoint == "issues" else f"https://api.github.com/repos/{repo}/pulls/{pull_number}/reviews"
        try:
            items = request_json(url, token=config.github_token, params={"per_page": str(min(config.max_github_items, 100))}, cache_dir=config.cache_dir, cache_ttl_seconds=config.cache_ttl_seconds)
            for item in items:
                timestamp = item.get("submitted_at") or item.get("updated_at") or item.get("created_at")
                if not event_time_in_window(timestamp, window):
                    continue
                prefix = f"PR #{pull_number}:"
                body = (item.get("body") or item.get("state") or "").splitlines()[0][:120]
                add_record(records, source=source, kind=kind, repo=repo, summary=f"{prefix} {body}".strip(), timestamp=ti